          valueFormatter={formatCompact}
          axisFormatter={(value) => formatCompact(value)}
        />

        <MetricBarChart
          title="Agent Handoffs"
          subtitle="Inter-agent delegations during execution (live)"
          data={comparisonData.map((item) => ({
            label: item.label,
            color: item.color,
            handoffs: item.handoffs
