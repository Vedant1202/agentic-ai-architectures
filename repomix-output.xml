.text-button {
  min-height: 32px;
  padding: 0 16px;
  font-size: 0.9rem;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  min-height: 32px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid transparent;
  font-weight: 600;
}

.status-pill.is-live {
  background: rgba(45, 212, 191, 0.12);
  border-color: rgba(45, 212, 191, 0.25);
  color: var(--accent-teal);
}

.status-pill.is-simulated {
  background: rgba(251, 191, 36, 0.12);
  border-color: rgba(251, 191, 36, 0.22);
  color: var(--accent-gold);
}

.project-intro {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
  gap: 16px;
  align-items: stretch;
  margin-top: 16px;
  padding: 24px;
  border-radius: 24px;
  border: 1px solid var(--panel-border);
  background: var(--panel-bg);
  box-shadow: var(--shadow-md);
  backdrop-filter: var(--glass-blur);
}

.project-intro h1 {
  max-width: 820px;
  margin: 8px 0 16px;
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  line-height: 1.02;
  letter-spacing: 0;
}

.project-intro p,
.runner-summary p,
.tour-overview p,
.metrics-guide p {
  margin: 0;
  color: var(--text-secondary);
  line-height: 1.5;
}

.project-intro > div > p {
  max-width: 860px;
  font-size: 1.04rem;
  margin-top: 12px;
}

.project-intro__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.inline-paper-link {
  display: inline-flex;
  align-items: center;
  min-height: 32px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid rgba(96, 165, 250, 0.26);
  background: rgba(96, 165, 250, 0.08);
  color: var(--accent-blue);
  text-decoration: none;
  font-size: 0.88rem;
  transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
}

.inline-paper-link:hover {
  transform: translateY(-1px);
  border-color: rgba(96, 165, 250, 0.5);
  background: rgba(96, 165, 250, 0.14);
}

.runner-summary {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 18px;
  border-radius: 18px;
  border: 1px solid var(--panel-border);
  background: var(--surface-muted);
}

.runner-summary span,
.metrics-guide span {
  font-size: 0.76rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

.runner-summary strong {
  font-size: 1.1rem;
}

.runner-summary__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: auto;
}

.runner-summary__meta span {
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  border: 1px solid var(--panel-border);
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-soft);
  font-size: 0.82rem;
  letter-spacing: 0;
  text-transform: none;
  font-weight: 700;
}

.stat-card {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 120px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid var(--panel-border);
  background: var(--surface-muted);
  overflow: hidden;
}

.stat-card strong,
.overview-card strong,
.mini-metric strong {
  font-size: 1.2rem;
  line-height: 1.2;
  word-break: break-word;
}

.stat-card small {
  color: var(--text-secondary);
  line-height: 1.55;
  font-size: 0.85rem;
  word-break: break-word;
}

.banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
  padding: 16px 18px;
  border-radius: 18px;
  border: 1px solid rgba(248, 113, 113, 0.22);
  background: rgba(248, 113, 113, 0.09);
  color: var(--text-soft);
}

.summary-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  margin: 16px 0;
}

.history-toggle-row {
  display: flex;
  justify-content: center;
  margin-top: 22px;
}

.history-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid var(--panel-border);
  background: var(--panel-bg);
  color: var(--text-secondary);
  cursor: pointer;
  transition: transform 180ms ease, border-color 180ms ease, color 180ms ease;
}

.history-toggle:hover {
  transform: translateY(-1px);
  border-color: rgba(96, 165, 250, 0.32);
  color: var(--text-primary);
}

.summary-strip-live {
  margin-top: 0;
}

.overview-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 140px;
  padding: 16px;
  border-radius: 24px;
  border: 1px solid var(--panel-border);
  background: var(--panel-bg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.overview-card p {
  margin: 0;
  color: var(--text-secondary);
  line-height: 1.55;
  font-size: 0.9rem;
  word-break: break-word;
}

.tone-blue {
  box-shadow: inset 0 1px 0 rgba(96, 165, 250, 0.22), var(--shadow-md);
}

.tone-teal {
  box-shadow: inset 0 1px 0 rgba(45, 212, 191, 0.22), var(--shadow-md);
}

.tone-gold {
  box-shadow: inset 0 1px 0 rgba(251, 191, 36, 0.22), var(--shadow-md);
}

.tone-slate {
  box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.2), var(--shadow-md);
}

.panel {
  margin-top: 16px;
  padding: 24px;
  border-radius: 30px;
  border: 1px solid var(--panel-border);
  background: var(--panel-bg);
  box-shadow: var(--shadow-lg);
}

.panel-spacious {
  padding: 24px;
}

.tour-overview {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 18px;
  align-items: center;
  background:
    linear-gradient(180deg, rgba(96, 165, 250, 0.05), transparent),
    var(--panel-bg);
}

.tour-overview h2 {
  margin: 4px 0 8px;
  font-size: clamp(1.15rem, 1.5vw, 1.5rem);
  line-height: 1.15;
}

.tour-overview__button {
  min-width: 164px;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 18px;
  margin-bottom: 26px;
}

.panel-header h2,
.selection-header h3,
.chart-panel__header h3,
.architecture-stack__header h3,
.task-preview h3,
.run-card__header h3 {
  margin: 4px 0 8px;
  font-size: clamp(1.25rem, 2vw, 1.5rem);
  line-height: 1.1;
}

.tutorial-stack {
  display: flex;
  flex-wrap: wrap;
  grid-column: 1 / -1;
  gap: 8px;
  align-items: center;
  padding-top: 18px;
  border-top: 1px solid var(--panel-border);
}

.tutorial-stack span,
.tutorial-stack strong {
  display: inline-flex;
  align-items: center;
  min-height: 30px;
  padding: 0 10px;
  border-radius: 999px;
  border: 1px solid var(--panel-border);
  background: rgba(255, 255, 255, 0.03);
  font-size: 0.82rem;
}

.tutorial-stack span {
  color: var(--text-secondary);
}

.tutorial-stack strong {
  color: var(--text-soft);
}

.insights-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 340px;
  gap: 16px;
}

.chart-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.chart-panel {
  padding: 16px;
  border-radius: 26px;
  border: 1px solid var(--panel-border);
  background: linear-gradient(180deg, var(--panel-bg-strong), var(--panel-bg));
}

.chart-panel__header {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 12px;
}

.chart-panel__body {
  height: 260px;
}

.chart-tooltip {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 10px 12px;
  border-radius: 14px;
  border: 1px solid var(--panel-border-strong);
  background: var(--panel-bg-strong);
  box-shadow: var(--shadow-md);
}

.chart-tooltip strong {
  font-size: 0.95rem;
}

.chart-tooltip span {
  color: var(--text-secondary);
}

.architecture-stack {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.architecture-stack__header {
  padding: 8px 4px 2px;
}

.architecture-summary {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid color-mix(in srgb, var(--card-accent) 28%, var(--panel-border));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent), var(--surface-muted);
}

.architecture-summary__topline,
.run-card__header,
.trace-feed__header,
.runner-footer,
.task-preview__header,
.architecture-option__topline {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.architecture-summary__topline span,
.architecture-option__topline span {
  font-weight: 700;
}

.architecture-summary__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  color: var(--text-secondary);
  font-size: 0.92rem;
}

.control-layout {
  display: grid;
  grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
  gap: 16px;
}

.control-column,
.selection-column {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.input-group label {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text-soft);
}

select,
textarea,
input {
  width: 100%;
  padding: 8px 16px;
  border-radius: 18px;
  border: 1px solid var(--panel-border);
  background: var(--surface-muted);
  color: var(--text-primary);
  transition: border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
}

textarea {
  min-height: 120px;
  resize: vertical;
}

select:focus,
textarea:focus,
input:focus {
  outline: none;
  border-color: rgba(96, 165, 250, 0.42);
  box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.12);
}

.task-preview {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding: 22px;
  border-radius: 24px;
  border: 1px solid var(--panel-border);
  background: var(--surface-muted);
}

.task-preview__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.task-category {
  padding: 8px 12px;
  border-radius: 999px;
  border: 1px solid var(--panel-border);
  background: rgba(255, 255, 255, 0.04);
}

.focus-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.focus-pills-criteria {
  margin-top: 12px;
}

.focus-pill {
  padding: 10px 12px;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.08);
  border: 1px solid rgba(96, 165, 250, 0.18);
  color: var(--text-soft);
  font-size: 0.9rem;
}

.focus-pill-criterion {
  border-radius: 14px;
  line-height: 1.45;
}

.task-criteria {
  border-top: 1px solid var(--panel-border);
  padding-top: 12px;
}

.task-criteria summary {
  cursor: pointer;
  color: var(--text-soft);
  font-weight: 600;
}

.selection-header {
  padding: 2px 4px;
}

.architecture-selector-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.architecture-option {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 18px;
  min-height: 174px;
  border-radius: 24px;
  border: 1px solid var(--panel-border);
  background: var(--surface-muted);
  text-align: left;
  cursor: pointer;
  transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.architecture-option:hover {
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--card-accent) 32%, var(--panel-border));
}

.architecture-option p,
.architecture-option small {
  margin: 0;
  color: var(--text-secondary);
  line-height: 1.55;
}

.architecture-option strong {
  font-size: 0.8rem;
  color: color-mix(in srgb, var(--card-accent) 75%, white);
}

.architecture-option.active {
  border-color: color-mix(in srgb, var(--card-accent) 46%, var(--panel-border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--card-accent) 12%, transparent), transparent),
    var(--surface-muted);
  box-shadow: 0 18px 30px color-mix(in srgb, var(--card-accent) 16%, transparent);
}

.helper-copy {
  display: flex;
  flex-direction: column;
  gap: 4px;
  color: var(--text-secondary);
}

.metrics-guide {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px dashed var(--panel-border-strong);
  background: rgba(96, 165, 250, 0.04);
}

.run-btn {
  min-height: 40px;
  padding: 0 16px;
  border: none;
  border-radius: 999px;
  background: linear-gradient(135deg, #2563eb, #38bdf8);
  color: white;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 18px 28px rgba(37, 99, 235, 0.28);
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.run-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 22px 32px rgba(37, 99, 235, 0.32);
}

.run-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  box-shadow: none;
}

.tour-highlight {
  position: relative;
  z-index: 30;
  outline: 3px solid rgba(96, 165, 250, 0.62);
  outline-offset: 5px;
  box-shadow: 0 0 0 8px rgba(96, 165, 250, 0.12), var(--shadow-lg);
}

.tour-card {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 60;
  width: min(430px, calc(100vw - 32px));
  padding: 18px;
  border-radius: 20px;
  border: 1px solid var(--panel-border-strong);
  background: var(--panel-bg-strong);
  box-shadow: var(--shadow-lg);
  backdrop-filter: var(--glass-blur);
}

.tour-card__topline,
.tour-card__actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.tour-card__topline span {
  font-size: 0.76rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-blue);
  font-weight: 800;
}

.tour-card__close {
  border: none;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  font-weight: 700;
}

.tour-card__progress {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 14px 0 12px;
  color: var(--text-secondary);
  font-size: 0.84rem;
  font-weight: 700;
}

.tour-card__progress > div {
  flex: 1;
  height: 6px;
  border-radius: 999px;
  background: var(--surface-soft);
  overflow: hidden;
}

.tour-card__progress i {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--accent-blue), var(--accent-teal));
}

.tour-card h2 {
  margin: 0 0 8px;
  font-size: 1.25rem;
  line-height: 1.2;
}

.tour-card p {
  margin: 0 0 16px;
  color: var(--text-secondary);
  line-height: 1.6;
}

.tour-card__actions .text-button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
  transform: none;
}

.tour-card__actions .run-btn {
  min-height: 42px;
}

.live-dashboard {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.live-run-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 18px;
  align-items: start;
}

.run-card {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 18px;
  border-radius: 28px;
  border: 1px solid color-mix(in srgb, var(--card-accent) 20%, var(--panel-border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--card-accent) 6%, transparent), transparent),
    var(--panel-bg);
}

.run-card.status-running {
  box-shadow: 0 20px 42px color-mix(in srgb, var(--card-accent) 14%, transparent);
}

.status-chip {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.status-running {
  background: rgba(96, 165, 250, 0.12);
  color: var(--accent-blue);
  border: 1px solid rgba(96, 165, 250, 0.2);
}

.status-complete {
  background: rgba(52, 211, 153, 0.12);
  color: var(--success-color);
  border: 1px solid rgba(52, 211, 153, 0.2);
}

.status-error {
  background: rgba(248, 113, 113, 0.12);
  color: var(--error-color);
  border: 1px solid rgba(248, 113, 113, 0.22);
}

.status-idle {
  background: rgba(148, 163, 184, 0.1);
  color: var(--text-secondary);
  border: 1px solid rgba(148, 163, 184, 0.16);
}

.run-card__metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.mini-metric {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 10px 11px;
  border-radius: 14px;
  border: 1px solid var(--panel-border);
  background: rgba(255, 255, 255, 0.03);
  overflow: hidden;
  text-align: left;
  min-width: 0;
}

.mini-metric > span:first-child {
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-metric strong {
  font-size: 1.05rem;
  line-height: 1.15;
  word-break: break-word;
}

.mini-metric__sublabel {
  font-size: 0.72rem;
  color: var(--text-secondary);
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Live token strip */
.run-card__live-strip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  border-radius: 14px;
  border: 1px solid var(--panel-border);
  background: rgba(96, 165, 250, 0.05);
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.live-token-counter strong {
  color: var(--accent-blue);
  font-size: 1rem;
  font-weight: 700;
  margin-right: 4px;
}

.live-duration {
  font-variant-numeric: tabular-nums;
  font-size: 0.85rem;
}

/* Evaluation section */
.run-card__eval-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.eval-section-header {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.eval-pending-badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(251, 191, 36, 0.12);
  border: 1px solid rgba(251, 191, 36, 0.22);
  color: var(--accent-gold);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* Live badge */
.live-badge {
  display: inline-flex;
  align-items: center;
  padding: 1px 7px;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.14);
  border: 1px solid rgba(96, 165, 250, 0.28);
  color: var(--accent-blue);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-left: 4px;
  vertical-align: middle;
}

/* Metric table (expanded details) */
.metric-table-section {
  margin-bottom: 18px;
}

.metric-table-section:last-child {
  margin-bottom: 0;
}

.metric-table-heading {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-secondary);
  font-weight: 700;
  margin-bottom: 8px;
}

.error-heading {
  color: var(--error-color);
}

.metric-table-note {
  margin: 0 0 8px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.metric-rationale {
  margin: 0;
  font-size: 0.88rem;
  color: var(--text-soft);
  line-height: 1.6;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid var(--panel-border);
  background: var(--surface-muted);
}

.metric-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

.metric-row td {
  padding: 7px 0;
  border-bottom: 1px solid var(--panel-border);
  vertical-align: middle;
  line-height: 1.4;
}

.metric-row:last-child td {
  border-bottom: none;
}

.metric-row__label {
  color: var(--text-secondary);
  width: 44%;
  padding-right: 12px;
}

